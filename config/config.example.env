# Polymarket Weather Bot Configuration
# Copy this file to .env and fill in your values

# === Polymarket Authentication ===
# Your Polygon wallet private key (never commit this!)
POLY_PRIVATE_KEY=your_private_key_here

# Signature type: 0=EOA, 1=Email/Magic, 2=Browser/Safe (most common)
POLY_SIGNATURE_TYPE=2

# Funder address (for proxy wallets, same as private key address for EOA)
POLY_FUNDER_ADDRESS=your_wallet_address_here

# Polymarket CLOB API host
POLY_HOST=https://clob.polymarket.com

# Polygon Chain ID (137 = mainnet)
POLY_CHAIN_ID=137

# === Trading Configuration ===
# Maximum position size per market (in USDC)
MAX_POSITION_SIZE=100

# Maximum total exposure (in USDC)
MAX_TOTAL_EXPOSURE=500

# Minimum edge required to place bet (0.05 = 5% edge)
MIN_EDGE_THRESHOLD=0.05

# Order type: GTC (Good Til Cancelled), FOK (Fill or Kill), FAK (Fill and Kill)
ORDER_TYPE=GTC

# === Weather API ===
# NOAA API endpoint (free, no key needed)
WEATHER_API_SOURCE=noaa

# Alternative: OpenWeatherMap (requires API key)
# WEATHER_API_SOURCE=openweathermap
# OPENWEATHER_API_KEY=your_api_key_here

# Locations to monitor (lat,lon)
# Format: name:lat:lon (comma-separated for multiple)
WEATHER_LOCATIONS=Miami:25.7617:-80.1918,NewYork:40.7128:-74.0060,LA:34.0522:-118.2437

# === Bot Behavior ===
# Check interval in seconds
CHECK_INTERVAL=60

# Enable live trading (false = paper trading / dry run)
LIVE_TRADING=false

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# === VPS Deployment ===
# Run as systemd service on VPS
# See deploy/README.md for setup instructions
